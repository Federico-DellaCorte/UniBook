{{!--
  Pagina dei risultati della ricerca risorse lato utente.

  Questo file è scritto in HTML con sintassi Handlebars.
  È una pagina vera e propria, non un partial: quando Express renderizza
  pages/resources/search-results, il contenuto di questo file viene inserito
  dentro {{{body}}} del layout principale main.hbs.

  Questa pagina viene usata quando l'utente effettua una ricerca avanzata dalla
  sezione risorse. I filtri possono riguardare:
    - tipologia della risorsa;
    - data;
    - ora di inizio e ora di fine;
    - capienza minima;
    - parola chiave.

  Il form di ricerca non viene riscritto qui, ma incluso tramite il partial:

    {{> resources-search-form}}

  In questo modo lo stesso form può essere riutilizzato sia nella pagina delle
  categorie sia nella pagina dei risultati.

  Le risorse mostrate arrivano dalla variabile resources, preparata dalla rotta
  GET /resources in resources.routes.js. Ogni risorsa è già stata filtrata lato
  server e contiene i dati necessari alla card: nome, tipo, capienza, posizione,
  descrizione, disponibilità sintetica e, se presente, capienza residua.

  La capienza residua viene mostrata solo quando la ricerca include una fascia
  oraria completa, cioè data + ora inizio + ora fine. Solo in quel caso ha senso
  dire quanti posti sono disponibili in quello specifico intervallo.

  Se nessuna risorsa rispetta i filtri, la pagina mostra uno stato vuoto invece
  di una griglia senza contenuto.
--}}

{{!-- Contenitore principale della pagina risultati. --}}
<main class="page">
  {{!-- Intestazione: ritorno alle categorie, titolo e numero di risultati trovati. --}}
  <header class="page-header">
    <a href="/resources" class="page-header__back">← Tutte le categorie</a>
    <h1 class="page-header__title">Risultati ricerca</h1>
    <p class="page-header__subtitle">{{countText}}</p>
  </header>

  {{!-- Form di ricerca riutilizzato, già compilato con i filtri correnti. --}}
  {{> resources-search-form}}

  {{!-- Se la ricerca ha prodotto risultati, mostro la griglia delle risorse. --}}
  {{#if resources.length}}
  {{!-- Griglia delle risorse compatibili con i filtri di ricerca. --}}
    <div class="resource-grid">
      {{!-- Ciclo Handlebars: ogni risorsa compatibile genera una card. --}}
      {{#each resources}}
        {{!-- Card della singola risorsa trovata dalla ricerca. --}}
        <article class="resource-card">
          {{!-- Testata della card: nome della risorsa e badge della tipologia. --}}
          <header class="resource-card__head">
            <h2 class="resource-card__title">{{name}}</h2>
            <span class="badge badge--{{type}}">{{typeLabel}}</span>
          </header>
          {{!-- Metadati principali della risorsa: capienza e posizione. --}}
          <dl class="resource-card__meta">
            <div>
              <dt>Capienza</dt>
              <dd>{{capacity}}</dd>
            </div>
            <div>
              <dt>Posizione</dt>
              <dd>{{location}}</dd>
            </div>
          </dl>
          {{!-- Descrizione opzionale: viene mostrata solo se presente. --}}
          {{#if description}}
            <p class="resource-card__description">{{description}}</p>
          {{/if}}

          {{!-- Sintesi della disponibilità settimanale, già preparata lato server. --}}
          {{#if availabilitySummary.length}}
            <div class="resource-card__availability">
              <span class="resource-card__availability-label">Disponibilità</span>
              <ul class="resource-card__availability-list">
                {{#each availabilitySummary}}
                  <li>{{this}}</li>
                {{/each}}
              </ul>
            </div>
          {{/if}}

          {{!--
  Capienza residua nell'intervallo richiesto.

  ../hasIntervalFilter usa il contesto esterno al ciclo resources.
  Viene mostrata solo se la ricerca include data, ora inizio e ora fine.
--}}
          {{#if ../hasIntervalFilter}}
            <p class="resource-card__remaining">
              Posti disponibili nell'intervallo richiesto:
              <strong>{{remainingSeats}}/{{capacity}}</strong>
            </p>
          {{/if}}

          {{!-- Link alla scheda dettaglio della risorsa. --}}
          <a class="resource-card__link" href="/resources/{{id}}">Apri scheda →</a>
        </article>
      {{/each}}
    </div>

  {{!-- Stato vuoto: mostrato quando nessuna risorsa rispetta i filtri. --}}
  {{else}}
    <p class="empty-state">
      Nessuna risorsa corrisponde ai criteri di ricerca. Prova ad
      allentare i filtri (più categoria, meno capienza, intervallo
      più ampio).
    </p>
  {{/if}}
</main>
